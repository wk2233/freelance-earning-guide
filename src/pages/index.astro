---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const articles = await getCollection('articles');
const sorted = articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tagClass: Record<string, string> = {
  programming: 'tag-prog',
  design: 'tag-design',
  writing: 'tag-writing',
  marketing: 'tag-mkt',
};
const catLabel: Record<string, string> = {
  programming: '编程开发',
  design: '设计创意',
  writing: '写作内容',
  marketing: '营销增长',
};
---

<BaseLayout title="不上班，也能自由赚钱" description="系统化指导数字技能自由职业赚钱。覆盖编程、设计、写作、营销 — 从零基础到高手进阶。">

<!-- Hero -->
<section class="hero">
  <div class="hero-bg">
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-orb hero-orb-3"></div>
    <div class="hero-particles"></div>
  </div>

  <div class="hero-content">
    <div class="hero-badge">
      <span class="hero-badge-dot"></span> 从零到自由 · 系统化路径
    </div>
    <h1>不上班，也能<br/><span class="gradient">自由赚钱</span></h1>
    <p>系统掌握编程、设计、写作、营销四大数字技能。从零基础到高手进阶，实现时间和地点的真正自由。</p>
    <div class="hero-actions">
      <a href="/freelance-earning-guide/programming/" class="btn btn-primary">🚀 开始自由之路</a>
      <a href="/freelance-earning-guide/about/" class="btn btn-outline">了解更多</a>
    </div>
    <div class="hero-stats">
      <div class="hero-stat"><div class="hero-stat-num">4</div><div class="hero-stat-label">技能分类</div></div>
      <div class="hero-stat"><div class="hero-stat-num">{articles.length}</div><div class="hero-stat-label">深度文章</div></div>
      <div class="hero-stat"><div class="hero-stat-num">∞</div><div class="hero-stat-label">赚钱可能</div></div>
    </div>
  </div>
</section>

<!-- Categories -->
<section style="padding:80px 24px">
  <div class="container">
    <div style="text-align:center;margin-bottom:48px" class="reveal">
      <span class="section-label">核心领域</span>
      <h2>选择你的自由之路</h2>
      <p style="color:var(--c-text-secondary);font-size:1.05rem">四大数字技能，总有一条适合你</p>
    </div>
    <div class="cat-grid">
      <a href="/freelance-earning-guide/programming/" class="cat-card reveal reveal-d1">
        <span class="cat-card-icon">💻</span>
        <h3>编程开发</h3>
        <p>远程接单 · 外包平台 · SaaS</p>
      </a>
      <a href="/freelance-earning-guide/design/" class="cat-card reveal reveal-d2">
        <span class="cat-card-icon">🎨</span>
        <h3>设计创意</h3>
        <p>UI/UX · Figma · 品牌设计</p>
      </a>
      <a href="/freelance-earning-guide/writing/" class="cat-card reveal reveal-d3">
        <span class="cat-card-icon">✍️</span>
        <h3>写作内容</h3>
        <p>AI 写作 · 自媒体 · 接单</p>
      </a>
      <a href="/freelance-earning-guide/marketing/" class="cat-card reveal reveal-d4">
        <span class="cat-card-icon">📈</span>
        <h3>营销增长</h3>
        <p>SEO · 联盟营销 · 电商</p>
      </a>
    </div>
  </div>
</section>

<!-- Article List -->
<section style="padding:0 24px 80px">
  <div class="container" style="max-width:900px">
    <div style="margin-bottom:48px" class="reveal">
      <span class="section-label">最新文章</span>
      <h2>📝 系统化赚钱指南</h2>
      <p style="color:var(--c-text-secondary);font-size:1.05rem">每篇都是干货，可复制的自由职业路径</p>
    </div>

    {sorted.length === 0 ? (
      <div class="reveal" style="text-align:center;padding:80px 0;background:var(--c-surface);border-radius:var(--radius-lg)">
        <div style="font-size:3rem;margin-bottom:16px">📝</div>
        <p style="color:var(--c-text-muted);font-size:1.1rem">文章正在撰写中，敬请期待！</p>
      </div>
    ) : (
      <div class="article-list">
        {sorted.map((a, i) => (
          <article class={`article-card reveal reveal-d${Math.min(i+1, 5)}`}>
            <a href={`/freelance-earning-guide/${a.data.category}/${a.slug}/`}>
              <div class="article-card-meta">
                <span class={`article-card-tag ${tagClass[a.data.category] || 'tag-prog'}`}>
                  {catLabel[a.data.category]}
                </span>
                <span class="article-card-date">
                  {a.data.date.toLocaleDateString('zh-CN', { year:'numeric', month:'2-digit', day:'2-digit' })}
                </span>
                {a.data.readingTime && <span class="article-card-date">{a.data.readingTime} min</span>}
              </div>
              <h2>{a.data.title}</h2>
              <p>{a.data.description}</p>
              {a.data.tags.length > 0 && (
                <div class="article-card-tags">
                  {a.data.tags.map(t => <span>{t}</span>)}
                </div>
              )}
            </a>
          </article>
        ))}
      </div>
    )}
  </div>
</section>

<!-- CTA -->
<section style="padding:0 24px 100px">
  <div class="container reveal" style="max-width:800px">
    <div class="cta">
      <div class="cta-inner">
        <h2>📬 订阅每周自由职业攻略</h2>
        <p>免费获取最新自由职业机会、实操指南和工具推荐</p>
        <form class="cta-form">
          <input type="email" class="cta-input" placeholder="输入你的邮箱" required />
          <button type="submit" class="cta-btn">🚀 免费订阅</button>
        </form>
        <p style="font-size:.8rem;opacity:.5;margin-top:16px">不发送垃圾邮件 · 随时可取消</p>
      </div>
    </div>
  </div>
</section>

</BaseLayout>
