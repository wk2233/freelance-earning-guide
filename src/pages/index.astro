---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const articles = await getCollection('articles');
const sortedArticles = articles
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = [
  { slug: 'all', label: '全部' },
  { slug: 'programming', label: '编程开发' },
  { slug: 'design', label: '设计创意' },
  { slug: 'writing', label: '写作内容' },
  { slug: 'marketing', label: '营销增长' },
];

const pageTitle = '不上班，也能自由赚钱';
const pageDescription = '系统化指导数字技能自由职业赚钱。覆盖编程、设计、写作、营销，从零基础到高手进阶。';
---

<BaseLayout title={pageTitle} description={pageDescription}>

<!-- Hero Section -->
<section class="bg-orange-50 border-b border-orange-100">
  <div class="max-w-3xl mx-auto px-4 py-16 md:py-20 text-center">
    <h1 class="text-3xl md:text-4xl font-bold text-orange-700 mb-4">
      不上班，也能自由赚钱 ✨
    </h1>
    <p class="text-lg text-stone-500 mb-8">
      从 0 到 1 掌握数字技能 · 实现时间和地点自由
    </p>
    <p class="text-sm text-stone-400">
      📚 系统化指南 &nbsp;·&nbsp; 💼 真实案例 &nbsp;·&nbsp; 🛠️ 实用工具
    </p>
  </div>
</section>

<!-- Category Filter -->
<section class="max-w-5xl mx-auto px-4 py-8">
  <div class="flex flex-wrap gap-2 justify-center" id="category-filters">
    {categories.map(cat => (
      <a
        href={cat.slug === 'all' ? '/' : `/${cat.slug}`}
        class={`category-chip px-4 py-2 rounded-full text-sm font-medium transition-colors no-underline
          ${cat.slug === 'all'
            ? 'bg-orange-500 text-white'
            : 'bg-stone-100 text-stone-500 hover:bg-orange-100 hover:text-orange-600'}`}
        data-category={cat.slug}
      >
        {cat.label}
      </a>
    ))}
  </div>
</section>

<!-- Article List -->
<section class="max-w-3xl mx-auto px-4 pb-16">
  {sortedArticles.length === 0 ? (
    <div class="text-center py-20">
      <p class="text-stone-400 text-lg">📝 文章正在撰写中，敬请期待！</p>
    </div>
  ) : (
    <div class="space-y-6">
      {sortedArticles.map(article => {
        const catLabel = categories.find(c => c.slug === article.data.category)?.label || article.data.category;
        return (
          <article class="bg-white border border-orange-50 rounded-xl p-6 hover:shadow-md hover:border-orange-200 transition-all">
            <a href={`/${article.data.category}/${article.slug}`} class="no-underline">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs font-medium text-orange-500 bg-orange-50 px-2 py-0.5 rounded-full">
                  {catLabel}
                </span>
                <span class="text-xs text-stone-400">
                  {article.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })}
                </span>
                {article.data.readingTime && (
                  <span class="text-xs text-stone-400">· {article.data.readingTime} min 阅读</span>
                )}
              </div>
              <h2 class="text-xl font-bold text-stone-800 mb-2 hover:text-orange-600 transition-colors">
                {article.data.title}
              </h2>
              <p class="text-stone-500 text-sm leading-relaxed">{article.data.description}</p>
            </a>
          </article>
        );
      })}
    </div>
  )}
</section>

</BaseLayout>
