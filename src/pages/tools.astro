---
import BaseLayout from '../layouts/BaseLayout.astro';

const tools = [
  {
    title:'💼 接单平台', gradient:'linear-gradient(135deg,#6c5ce7,#4834d4)',
    items:[
      { name:'Upwork', desc:'全球最大自由职业平台' },
      { name:'Fiverr', desc:'新手友好，$5 起步' },
      { name:'程序员客栈', desc:'国内程序员接单首选' },
      { name:'猪八戒网', desc:'综合服务交易平台' },
    ],
  },
  {
    title:'🎨 设计工具', gradient:'linear-gradient(135deg,#00cec9,#00b894)',
    items:[
      { name:'Canva', desc:'零基础在线设计' },
      { name:'Figma', desc:'专业 UI/UX 设计' },
      { name:'Remove.bg', desc:'AI 一键去背景' },
    ],
  },
  {
    title:'✍️ 写作内容', gradient:'linear-gradient(135deg,#fd79a8,#e84393)',
    items:[
      { name:'Notion', desc:'全能写作+知识管理' },
      { name:'Grammarly', desc:'英文语法检查' },
      { name:'Hemingway', desc:'让文章更简洁' },
    ],
  },
  {
    title:'⚡ 效率工具', gradient:'linear-gradient(135deg,#00b894,#00cec9)',
    items:[
      { name:'Trello', desc:'项目管理看板' },
      { name:'Toggl', desc:'时间追踪计时' },
      { name:'Calendly', desc:'日程预约工具' },
    ],
  },
];
---

<BaseLayout title="工具推荐" description="自由职业者必备的接单平台、设计工具、写作工具和效率工具推荐">

<div style="padding:100px 24px 80px">
  <div class="container" style="max-width:780px">

    <div style="text-align:center;margin-bottom:56px" class="reveal">
      <span class="section-label">Resources</span>
      <h1>🛠️ 工具推荐</h1>
      <p style="color:var(--c-text-secondary);font-size:1.1rem;margin-top:16px">精选自由职业者必备工具，提高效率多赚钱</p>
      <div style="display:inline-block;margin-top:20px;padding:8px 20px;background:#fff3cd;border-radius:99px;font-size:.8rem;color:#856404">
        ℹ️ 部分链接可能含联盟推广
      </div>
    </div>

    {tools.map((cat, i) => (
      <div class={`tool-section reveal reveal-d${Math.min(i+1, 5)}`}>
        <div class="tool-section-head" style={`background:${cat.gradient}`}>{cat.title}</div>
        <div class="tool-grid">
          {cat.items.map(t => (
            <div class="tool-item">
              <h4>{t.name}</h4>
              <p>{t.desc}</p>
            </div>
          ))}
        </div>
      </div>
    ))}

    <div class="reveal" style="text-align:center;margin-top:48px">
      <a href="/freelance-earning-guide/" class="back-link">← 返回首页</a>
    </div>

  </div>
</div>

</BaseLayout>
