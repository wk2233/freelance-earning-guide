---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  return ['programming', 'design', 'writing', 'marketing'].map(cat => ({ params: { category: cat } }));
}

const { category } = Astro.params;
const meta: Record<string, { title:string;desc:string;icon:string;gradient:string }> = {
  programming: { title:'编程开发', desc:'远程接单、外包平台、独立开发、AI 编程工具', icon:'💻', gradient:'linear-gradient(135deg,#6c5ce7,#4834d4)' },
  design: { title:'设计创意', desc:'UI/UX、Canva、Figma、品牌设计、素材售卖', icon:'🎨', gradient:'linear-gradient(135deg,#00cec9,#00b894)' },
  writing: { title:'写作内容', desc:'AI 写作、自媒体、内容代写、文案接单', icon:'✍️', gradient:'linear-gradient(135deg,#fd79a8,#e84393)' },
  marketing: { title:'营销增长', desc:'SEO、社交媒体、联盟营销、跨境电商', icon:'📈', gradient:'linear-gradient(135deg,#00b894,#00cec9)' },
};
const m = meta[category!] || { title:category, desc:'', icon:'📂', gradient:'linear-gradient(135deg,#6c5ce7,#4834d4)' };

const articles = await getCollection('articles');
const catArticles = articles.filter(a => a.data.category === category)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tagClass: Record<string, string> = {
  programming: 'tag-prog', design: 'tag-design', writing: 'tag-writing', marketing: 'tag-mkt',
};
const catLabel: Record<string, string> = {
  programming: '编程开发', design: '设计创意', writing: '写作内容', marketing: '营销增长',
};
---

<BaseLayout title={`${m.title} - 分类`} description={m.desc}>

<section class="page-hero">
  <div class="page-hero-bg" style={`background:${m.gradient}`}></div>
  <div class="page-hero-inner">
    <div class="page-hero-icon">{m.icon}</div>
    <h1>{m.title}</h1>
    <p>{m.desc}</p>
    <p style="opacity:.6;font-size:.9rem;margin-top:12px">共 {catArticles.length} 篇文章</p>
  </div>
</section>

<div style="padding:40px 24px 80px">
  <div class="container" style="max-width:900px">
    <a href="/freelance-earning-guide/" class="back-link">← 返回首页</a>

    {catArticles.length === 0 ? (
      <div class="reveal" style="text-align:center;padding:80px 0;background:var(--c-surface);border-radius:var(--radius-lg)">
        <div style="font-size:3rem;margin-bottom:16px">📭</div>
        <p style="color:var(--c-text-muted);font-size:1.1rem">该分类暂无文章，敬请期待！</p>
      </div>
    ) : (
      <div class="article-list">
        {catArticles.map((a, i) => (
          <article class={`article-card reveal reveal-d${Math.min(i+1, 5)}`}>
            <a href={`/freelance-earning-guide/${a.data.category}/${a.slug}/`}>
              <div class="article-card-meta">
                <span class={`article-card-tag ${tagClass[a.data.category] || 'tag-prog'}`}>{catLabel[a.data.category]}</span>
                <span class="article-card-date">{a.data.date.toLocaleDateString('zh-CN', { year:'numeric', month:'2-digit', day:'2-digit' })}</span>
                {a.data.readingTime && <span class="article-card-date">· {a.data.readingTime} min</span>}
              </div>
              <h2>{a.data.title}</h2>
              <p>{a.data.description}</p>
            </a>
          </article>
        ))}
      </div>
    )}
  </div>
</div>

</BaseLayout>
