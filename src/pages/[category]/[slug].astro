---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(a => ({
    params: { category: a.data.category, slug: a.slug },
    props: { article: a },
  }));
}

const { article } = Astro.props;
const { Content, headings } = await article.render();

const allArticles = await getCollection('articles');
const related = allArticles
  .filter(a => a.data.category === article.data.category && a.slug !== article.slug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const catLabel: Record<string, string> = {
  programming: '编程开发', design: '设计创意', writing: '写作内容', marketing: '营销增长',
};
const tagClass: Record<string, string> = {
  programming: 'tag-prog', design: 'tag-design', writing: 'tag-writing', marketing: 'tag-mkt',
};
---

<BaseLayout title={article.data.title} description={article.data.description} ogType="article">

<div style="padding:80px 24px">
  <div class="article">
    <!-- Breadcrumb -->
    <div class="article-breadcrumb">
      <a href="/freelance-earning-guide/">首页</a><span>/</span>
      <a href={`/freelance-earning-guide/${article.data.category}/`}>{catLabel[article.data.category]}</a>
    </div>

    <!-- Header -->
    <header class="article-header reveal">
      <div class="article-card-meta" style="margin-bottom:16px">
        <span class={`article-card-tag ${tagClass[article.data.category] || 'tag-prog'}`}>
          {catLabel[article.data.category]}
        </span>
        <span class="article-card-date">
          {article.data.date.toLocaleDateString('zh-CN', { year:'numeric', month:'long', day:'numeric' })}
        </span>
        {article.data.readingTime && <span class="article-card-date">· {article.data.readingTime} min</span>}
      </div>
      <h1>{article.data.title}</h1>
      {article.data.tags.length > 0 && (
        <div class="article-card-tags">
          {article.data.tags.map(t => <span>{t}</span>)}
        </div>
      )}
    </header>

    <!-- TOC -->
    {headings.length > 1 && (
      <nav class="toc reveal">
        <h4>📋 目录</h4>
        {headings.map(h => (
          <a href={`#${h.slug}`} style={`padding-left:${(h.depth - 1) * 16}px`}>{h.text}</a>
        ))}
      </nav>
    )}

    <!-- Content -->
    <div class="article-body reveal">
      <Content />
    </div>

    <!-- CTA -->
    <div class="reveal" style="margin-top:64px">
      <div class="cta">
        <div class="cta-inner">
          <h2>📬 觉得有用？订阅更多</h2>
          <p>每周发送自由职业赚钱攻略到你的邮箱</p>
          <form class="cta-form">
            <input type="email" class="cta-input" placeholder="输入邮箱" required />
            <button type="submit" class="cta-btn">订阅</button>
          </form>
        </div>
      </div>
    </div>

    <!-- Related -->
    {related.length > 0 && (
      <div class="reveal" style="margin-top:64px">
        <h3 style="margin-bottom:24px">📖 相关文章</h3>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px">
          {related.map(ra => (
            <a href={`/freelance-earning-guide/${ra.data.category}/${ra.slug}/`}
               style="display:block;padding:24px;background:var(--c-surface);border-radius:var(--radius);transition:var(--transition);border:1px solid transparent"
               onmouseover="this.style.borderColor='var(--c-border)'"
               onmouseout="this.style.borderColor='transparent'">
              <span class={`article-card-tag ${tagClass[ra.data.category] || 'tag-prog'}`} style="margin-bottom:8px;display:inline-block">{catLabel[ra.data.category]}</span>
              <h4 style="font-size:.95rem;font-weight:600;line-height:1.4">{ra.data.title}</h4>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</div>

</BaseLayout>
