---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="关于我们" description="了解自由赚钱指南的使命和背后的故事">

<div style="padding:100px 24px 80px">
  <div class="container" style="max-width:780px">

    <div style="text-align:center;margin-bottom:64px" class="reveal">
      <span class="section-label">About</span>
      <h1>关于<span class="gradient" style="display:inline-block">自由赚钱指南</span></h1>
      <p style="color:var(--c-text-secondary);font-size:1.1rem;margin-top:16px">帮助 10,000 人实现不上班也能自由赚钱</p>
    </div>

    <div style="display:grid;gap:24px">
      <div class="reveal" style="background:var(--c-surface);border-radius:var(--radius-lg);padding:40px;border:1px solid var(--c-border)">
        <h3 style="margin-bottom:12px">🎯 我们的使命</h3>
        <p style="color:var(--c-text-secondary);line-height:1.8">
          自由赚钱指南致力于系统化地指导每一个人掌握数字技能，通过自由职业实现收入自由。
          无论你是零基础的职场新人，还是有技能但不知道如何变现的专业人士，这里都有适合你的内容。
        </p>
      </div>

      <div class="reveal reveal-d1" style="background:var(--c-bg);border-radius:var(--radius-lg);padding:40px;border:1px solid var(--c-border)">
        <h3 style="margin-bottom:16px">📚 四大领域</h3>
        <div style="display:grid;gap:16px">
          {[
            { icon:'💻', title:'编程开发', desc:'远程接单、外包平台、SaaS 独立开发、AI 编程工具' },
            { icon:'🎨', title:'设计创意', desc:'UI/UX 设计、Canva/Figma、品牌设计、设计接单' },
            { icon:'✍️', title:'写作内容', desc:'AI 写作、自媒体运营、内容代写、文案接单' },
            { icon:'📈', title:'营销增长', desc:'SEO、社交媒体营销、联盟营销、数字产品销售' },
          ].map(i => (
            <div style="display:flex;align-items:flex-start;gap:16px;padding:8px 0">
              <span style="font-size:1.5rem">{i.icon}</span>
              <div><strong style="font-size:.95rem">{i.title}</strong><br/><span style="font-size:.85rem;color:var(--c-text-muted)">{i.desc}</span></div>
            </div>
          ))}
        </div>
      </div>

      <div class="reveal reveal-d2" style="background:linear-gradient(135deg,#1a1a2e,#16213e);border-radius:var(--radius-lg);padding:40px;color:#fff">
        <h3 style="color:#fff;margin-bottom:12px">👋 关于站长</h3>
        <p style="color:rgba(255,255,255,.7);line-height:1.8">
          一个不想上班的程序员，相信数字技能可以让人摆脱朝九晚五的束缚。
          创建这个网站的目的是分享自由职业赚钱的路线图、工具和真实案例，帮助你少走弯路。
        </p>
      </div>

      <div class="reveal reveal-d3" style="text-align:center;padding:40px 0">
        <a href="/freelance-earning-guide/" class="btn btn-primary">🚀 开始自由之路</a>
      </div>
    </div>

  </div>
</div>

</BaseLayout>
